APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
# Em dev/local/test, DATABASE_URL pode ficar vazio e o app cai para SQLite local:
# sqlite+aiosqlite:///./deriv-organismo.db
DATABASE_URL=
# Em dev/local/test, REDIS_URL cai para redis://localhost:6379/0 se não for definido.
REDIS_URL=
DERIV_APP_ID=
DERIV_API_BASE_WS=wss://ws.derivws.com/websockets/v3
DERIV_API_BASE_REST=https://api.deriv.com
DEFAULT_ACCOUNT_SLUG=primary
ENABLE_MULTI_TENANT=false
