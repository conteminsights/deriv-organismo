APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
# Em dev/local/test, DATABASE_URL pode ficar vazio e o app cai para SQLite local.
DATABASE_URL=
# Em dev/local/test, REDIS_URL pode ficar vazio e cai para redis://localhost:6379/0.
REDIS_URL=
# Para payloads live Deriv, informe um app id válido.
DERIV_APP_ID=
DERIV_API_BASE_WS=wss://ws.derivws.com/websockets/v3
DERIV_API_BASE_REST=https://api.deriv.com
DEFAULT_ACCOUNT_SLUG=primary
ENABLE_MULTI_TENANT=false

# Secrets locais de desenvolvimento. Em produção, substitua por valores fortes e exclusivos.
APP_SECRET_KEY=dev-session-secret-key-change-in-prod
CREDENTIAL_SECRET_KEY=dev-credential-secret-key-change-in-prod

# Auth opcional. Se AUTH_ENABLED=true, preencha os blocos abaixo.
AUTH_ENABLED=false
MASTER_EMAIL=master@conteminsights.com
MASTER_PASSWORD=
TENANT_EMAIL=tenant@conteminsights.com
TENANT_PASSWORD=
TENANT_SCOPE_ID=tenant_demo
